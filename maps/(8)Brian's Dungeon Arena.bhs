{
    if (window_id == "info_win")
    {
        // bubble_text_cent_screen(Text(window_get_height()));
        // window_set_height((25 * num_players()) + 70);
    }
}

text ui_callback on_label_set_text_id(string window, string label_id, int id_num, text text_msg)
{
    if (window == "info_win")
    {
        if (id_num <= num_players())
            switch (label_id)
            {
            case "time":

                break;

            case "icons":
                string icon;
                if (id_num == 1)
                    icon = "#ICON135";
                else if (id_num == 2)
                    icon = "#ICON70";
                else if (id_num == 3)
                    icon = "#ICON47";
                return Text(parse(text_msg, Text(icon)));
                break;
            case "wins":
                return Text(parse(text_msg, Text(Wins[id_num - 1])));
                break;

            case "lastwins":
                if (count_wave != 0)
                {
                    set_label_color_to_team_color(window, label_id, get_leader(LastWins));
                    return Text(parse(text_msg, Text(get_leader_name(get_leader(LastWins)))));
                }
                break;

            case "kills":

                return Text(parse(text_msg, Text(num_kills(get_leader(id_num - 1)))));
                break;
            case "units":

                return Text(parse(text_msg, Text(num_units(get_leader(id_num - 1)))));
                break;

            case "leader1":
            case "leader2":
            case "leader3":
            case "leader4":
            case "leader5":
            case "leader6":
            case "leader7":
            case "leader8":

                //#ICON47
                String display;
                switch (id_num)
                {
                case 1:
                    set_label_color_to_team_color(window, label_id, get_leader(0));
                    display = get_leader_name(get_leader(0));
                    break;
                case 2:
                    set_label_color_to_team_color(window, label_id, get_leader(1));
                    display = get_leader_name(get_leader(1));
                    break;
                case 3:
                    set_label_color_to_team_color(window, label_id, get_leader(2));
                    display = get_leader_name(get_leader(2));
                    break;
                case 4:
                    set_label_color_to_team_color(window, label_id, get_leader(3));
                    display = get_leader_name(get_leader(3));
                    break;
                case 5:
                    set_label_color_to_team_color(window, label_id, get_leader(4));
                    display = get_leader_name(get_leader(4));
                    break;
                case 6:
                    set_label_color_to_team_color(window, label_id, get_leader(5));
                    display = get_leader_name(get_leader(5));
                    break;
                case 7:
                    set_label_color_to_team_color(window, label_id, get_leader(6));
                    display = get_leader_name(get_leader(6));
                    break;
                case 8:
                    set_label_color_to_team_color(window, label_id, get_leader(7));
                    display = get_leader_name(get_leader(7));
                    break;

                default:
                    break;
                }
                return Text(display);
                break;

            case "header":
                if (Time)
                    return Text(parse(text_msg, Text(Time_s), Text(Time_total)));
                else
                    return Text("Round " + count_wave);
                break;

            default:
                break;
            }
    }
}
String function sf_convert_to_clock(int time_in_seconds)
{
    String clock;
    int seconds;
    int minutes;

    minutes = time_in_seconds / 60;
    seconds = time_in_seconds % 60;

    if (seconds > 9)
    {
        clock = parse("$s0:$s1", minutes, seconds);
    }
    else
    {
        clock = parse("$s0:0$s1", minutes, seconds);
    }
    return clock;
}

Void function sf_unit_attack_to_nearest_unit(unit crunit)
{
    Leader curleader = get_unit_leader(crunit);
    Location curlocation = unit_location(crunit);
    Unit the_unit;
    Unit target_unit;
    UnitGroup allunit;

    int min_dist = 1000, dist;

    for (int l = 0; l < num_players(); l++)
    {
        if (get_leader(l) != curleader)
        {
            allunit = find_unit(get_leader(l), "$ALL$");
            for (int scan = 0; scan < unit_group_length(allunit); scan++)
            {
                the_unit = unit_at_index(allunit, scan);
                dist = locations_distance(curlocation, unit_location(the_unit));
                if (dist <= min_dist)
                {
                    min_dist = dist;
                    target_unit = the_unit;
                }
            }
            // clear_unit_group(allunit);
        }
    }
    unit_attack_to_unit(crunit, target_unit);
}