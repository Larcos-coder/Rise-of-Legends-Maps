text ui_callback on_label_set_text (String window_id, String id, text label_text) {
  // Yes you have to do this, believe it or not
  return label_text;  
}

text ui_callback on_label_set_text_id(string window, string label_id, int id_num, text text_msg)
{
    if (id_num < 1 || id_num > 22)
    {
        return "";
    }
    switch(id_num){
      case 1:
        return Text("course: " + course);
      case 2:
        return Text("army_size: " + parse(text_msg, army_size_test));
      case 3:
        return Text("Building_choice: " + test_string);
      case 4:
        return Text("Player 2 difficult: " + test_difficult);
      case 5:
        return Text("Building num: " + buildings_type_num);
      case 6:
        leader[] team_k = GLOBALS["FirstTeamGlobal"];
        return Text("Leaders: " + parse(text_msg, team_k[0]) + " " + parse(text_msg, team_k[1]) + " " +  parse(text_msg, team_k[2]));
      case 7:
        return Text("Region counter: " + parse(text_msg, test_counter) + parse(text_msg, test_scope));
      case 8:
        return Text("Region flag: " + parse(text_msg, test_flag));
      case 9:
        return Text("Locations: " + test_locations[0] + ";" + test_locations[1] + " " + test_locations[2] + ";" + test_locations[3]);
      case 10:
        return Text("Size: " + test_size);
      //case 11:
        //return Text("Combat groups: " + parse(text_msg,test_units[0]) + " " + parse(text_msg,test_units[1]));
    }
    if (label_id == "kills")
    {
        return Text(parse(text_msg, num_kills(get_leader(id_num - 1))));
    }
}