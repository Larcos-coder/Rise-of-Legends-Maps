    int unit_x = location_get_x(unit_location(the_unit));
    int delta_x = absl_int(unit_x - group_x);
    bool has_volley_buff = object_has_buff(the_unit, "Volley Fire Doge Elite");
    bool can_cast_loose = unit_can_cast("Loose Order Doge Elite", the_unit);
    bool can_cast_volley = unit_can_cast("Volley Fire Doge Elite", the_unit);
