    // Условие для Loose Order
    if (((unit_hp <= 80 || current_course != team || delta_x > 2 * DISTANCE || current_course == 3) &&
         has_volley_buff) && can_cast_loose) {
      add_unit_to_group("Main Group", the_unit);
      unit_cast_at_group("Volley Fire Doge Elite", the_unit, "VinciUn");
      clear_unit_group("Main Group");
      index--;
      processed++;
    }
    // Условие для Volley Fire
    else if (delta_x < DISTANCE && !has_volley_buff && !is_unit_under_attack(the_unit) &&
             unit_hp > 80 && current_course == team && can_cast_volley) {
      add_unit_to_group("Main Group", the_unit);
      unit_cast_at_group("Volley Fire Doge Elite", the_unit, "VinciUn");
      clear_unit_group("Main Group");
      index--;
      processed++;
    }
    test_size++;
  }
  scan_index = (scan_index + viewed) % total_units;
  frame_counter++;  // Увеличиваем счётчик кадров
  break;
case 8:
for(scan = 0; scan < unit_group_length("Shields"); scan++){
  the_unit = unit_at_index("Shields", scan);
  if(unit_can_cast("Personal Shield 1", the_unit) && is_unit_under_attack(the_unit)){
    unit_cast_at_unit("Personal Shield 1",the_unit, the_unit);
