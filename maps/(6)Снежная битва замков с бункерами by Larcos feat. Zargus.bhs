void game_callback on_game_frame() {
  static region[] AllReg = ["YellowR1", "YellowR2", "YellowR3", "YellowR4", "YellowR5", "GreenR5", "GreenR4", "GreenR3", "GreenR2", "GreenR1"];
  static region[] AllReg2 = ["GreenR1", "GreenR2", "GreenR3", "GreenR4", "GreenR5", "YellowR5", "YellowR4", "YellowR3", "YellowR2", "YellowR1"];
  static Location[] FirstTeamLoc = ["FirstTeam 11", "FirstTeam 12", "FirstTeam 21", "FirstTeam 22", "FirstTeam 31", "FirstTeam 32"];
  static Location[] SecondTeamLoc = ["SecondTeam 11", "SecondTeam 12", "SecondTeam 21", "SecondTeam 22", "SecondTeam 31", "SecondTeam 32"];
  static Leader[] NumL = ["1", "2", "3", "4", "5", "6", "7", "8"];
  static UnitType[] AllUnits = ["Condottieri Soldier", "Imperial Musketeer", "Doge Guard MP", "Doge Walker MP", "Juggernaut", "Dark Walker", "Glass Golem Poison", "Mega Glass Golem", "Condottieri Dragoon","Condottieri Knight", "Heretic", "Sentinel", "High Priest", "Sun Jaguar", "Death Snake", "Greater Idol", "Moon Gorilla", "Clockwork Man", "Hybrid Clockwork Man", "Demolition Clockwork Man", "Clockwork Spider", "Land Leviathan", "Veteran Fire Scout", "Quetzal", "Storm Eagle", "Storm Disk", "Cuotl Master Unit", "Pirata Flyer", "Gun Flyer", "Air Destroyer", "Siege Zeppelin", "Juvenile Salamander", "Adult Salamander", "Elder Salamander", "Marid", "Berserker", "Berserker Rider", "Siege Elephant", "Heartseeker", "Scorpion Rider", "Sand Horror", "Lava Spider", "Fire Golem", "Burning Cloud Unit", "Glass Spider Built Poison", "Giant Glass Spider", "Afreet", "Fireswarm", "Rukh", "Sand Dragon", "Glass Dragon Start", "Thuran, the Sky Inferno", "Dark Genie", "Death Sphere", "Clockwork Sniper", "Cave Drake", "Desert Walker", "Burrowing Spider"];
  static BuildType[] AllBuilds = ["Condottieri Soldier 00", "Imperial Musketeer 00", "Doge Guard MP 00", "Doge Walker MP 00", "Juggernaut 00", "Dark Walker 00", "Glass Golem Start 00", "Mega Glass Golem 00", "Condottieri Dragoon 00","Condottieri Knight 00", "Heretic 00", "Sentinel 00", "High Priest 00", "Sun Jaguar 00", "Death Snake 00", "Greater Idol 00", "Moon Gorilla 00", "Clockwork Man 00", "Hybrid Clockwork Man 00", "Demolition Clockwork Man 00", "Clockwork Spider 00", "Land Leviathan 00", "Veteran Fire Scout 00", "Quetzal 00", "Storm Eagle 00", "Storm Disk 00", "Cuotl Master Unit 00", "Pirata Flyer 00", "Gun Flyer 00", "Air Destroyer 00", "Siege Zeppelin 00", "Juvenile Salamander 00", "Adult Salamander 00", "Elder Salamander 00", "Marid 00", "Berserker 00", "Berserker Rider 00", "Siege Elephant 00", "Heartseeker 00", "Scorpion Rider 00", "Sand Horror 00", "Lava Spider 00", "Fire Golem 00", "Burning Cloud Unit 00", "Glass Spider Built Poison 00", "Giant Glass Spider 00", "Afreet 00", "Fireswarm 00", "Rukh 00", "Sand Dragon 00", "Glass Dragon Start 00", "Thuran, the Sky Inferno 00", "Dark Genie 00", "Death Sphere 00", "Clockwork Sniper 00", "Cave Drake 00", "Desert Walker 00", "Burrowing Spider 00"];

  static int counter_reset1[];
  static int counter_reset2[];
  static int counter_num_b1[];
  static int counter_num_b2[];
  static int counter1[];
  static int counter2[];

  GLOBALS["AllUnits"] = AllUnits;
  GLOBALS["AllBuilds"] = AllBuilds;

static Unit[] NotHe;
static int[] NotHe_kick;

  trigger(1){
    if(rand_int(0, 100) >= 50)NumL = ["8", "7", "6", "5", "4", "3", "2", "1"];
    for(int b = 0; b < 58; b++){
      add(counter_reset1, 90); 
      add(counter_reset2, 90);
      add(counter_num_b1, 0);
      add(counter_num_b2, 0); 
      add(counter1, 0); 
      add(counter2, 0); 
    }
  }

  static int NumActive = 0;
  static Leader[] FirstTeam = ["", "", ""];
  static Leader[] SecondTeam = ["", "", ""];
  GLOBALS["AllReg"] = AllReg;
  GLOBALS["AllReg2"] = AllReg2;

  run_once{
    set_timer("Castle max health timer", 300);
    set_timer("Test", 5);
    //show_script_window("LARCOS_DEBUG");
    dominances_disable();
    for(int i = 0; i<8; i++){
     set_commerce_cap(NumL[i],1000);
     set_population_cap(NumL[i],300);
     diplo_disable(NumL[i]);
     research_disable(NumL[i]);
     remove_all_cooldowns(NumL[i]);
     set_base_rate(NumL[i], "timonium", -10);
     if(i < 6)set_explored(FirstTeamLoc[i],(NumL[i]), 200);
     if(i < 6)set_explored(SecondTeamLoc[i],(NumL[i]), 200);
     set_explored("Yellow BOOM",(NumL[i]), 200);
     set_explored("Green BOOM",(NumL[i]), 200);
     give_good(NumL[i], "Wealth", 50);
     give_good(NumL[i], "Energy", 50);
     leader_gain_tech(NumL[i], "Castle Fight Buff");
    }
     //enable_type("Castle Fight Buff Bonus");
     //leader_gain_tech("1", "Castle Fight Buff Bonus");
    set_timer("counter", 1);
    set_timer("Fight AI", 1);
    set_timer("Changing time of day", rand_int(600, 900));

// ====================== Who is Who ========================
 
  for(int a = 0; a < 8; a++){
    if(leader_is_active(NumL[a])){
      Active[NumActive] = NumL[a];
      NumActive++;
    }
  }
  GLOBALS["NumActive"] = NumActive;
  for(int y = 0, j = 0, g = 0; y < NumActive; y++){
    if(have_alliance(Active[0],Active[y])){
      FirstTeam[j] = Active[y];
      j++;
    }
    else{
      SecondTeam[g] = Active[y];
      g++;
    }
  }
  for(int p = 0; p < 3; p++){
    if(leader_is_active(FirstTeam[p])){
      ArrayActive[0]++;
    }
  }
  for(int s = 0; s < 3; s++){
    if(leader_is_active(SecondTeam[s])){
      ArrayActive[1]++;
    }
  }
  GLOBALS["FirstTeamGlobal"] = FirstTeam;
  GLOBALS["SecondTeamGlobal"] = SecondTeam;
  GLOBALS["Active"] = Active;
  GLOBALS["ArrayActive"] = ArrayActive;

    Leader CastleLeader = FirstTeam[rand_int(0, ArrayActive[0])];
    Leader CastleLeader2 = SecondTeam[rand_int(0, ArrayActive[1])];
    GLOBALS["CastleLeader"] = CastleLeader;
    GLOBALS["CastleLeader2"] = CastleLeader2;
    for(int x = 0; x < NumActive; x++){
      Build Castle = find_building(Active[x],"Castle for win");
      BuildGroup Hammer = find_building(Active[x],"Doge's Hammer");
	  BuildGroup Bunker = find_building(Active[x],"Bunker");
      if(get_building_leader(Castle) != CastleLeader){
        destroy_building(Castle);
        destroy_building(building_at_index(Hammer, 0));
		destroy_building(building_at_index(Bunker, 1));
      }
      Castle = find_building(Active[x],"Castle for win 2");
      if(get_building_leader(Castle) != CastleLeader2){
        destroy_building(Castle);
        destroy_building(building_at_index(Hammer, 1));
		destroy_building(building_at_index(Bunker, 0));
      }
      if(get_building_leader(building_at_index(Hammer, 0)) != CastleLeader2 && get_building_leader(building_at_index(Hammer, 0)) != CastleLeader){
        destroy_building(building_at_index(Hammer, 0));
        destroy_building(building_at_index(Hammer, 1));
		destroy_building(building_at_index(Bunker, 1));
		destroy_building(building_at_index(Bunker, 0));
      }
    }

  switch(ArrayActive[0]){
    case 1:
      FirstTeamLoc[0] = FirstTeamLoc[2];
      FirstTeamLoc[1] = FirstTeamLoc[3];
      break;
    case 2:
      FirstTeamLoc[2] = FirstTeamLoc[4];
      FirstTeamLoc[3] = FirstTeamLoc[5];
      break;
  }
  switch(ArrayActive[1]){
    case 1:
      SecondTeamLoc[0] = SecondTeamLoc[2];
      SecondTeamLoc[1] = SecondTeamLoc[3];
      break;
    case 2:
      SecondTeamLoc[2] = SecondTeamLoc[4];
      SecondTeamLoc[3] = SecondTeamLoc[5];
      break;
  }
  for(int k = 0; k < 3; k++){
    create_building(FirstTeam[k], "Timonium income 1", FirstTeamLoc[k*2]);
    create_building(FirstTeam[k], "Gold income 1",  FirstTeamLoc[k*2 + 1]);
    create_building(SecondTeam[k], "Timonium income 1", SecondTeamLoc[k*2]);
    create_building(SecondTeam[k], "Gold income 1", SecondTeamLoc[k*2 + 1]);
  }
}
// ======================= Victory ==========================
 int scan, scan2, scan3;
 Unit the_unit;
 Unit the_target;
 UnitType the_unit_type;
 UnitGroup the_unit_group;
 region[] BattleRegions;
 static Build YellowCastle = find_building(GLOBALS["CastleLeader2"], "Castle for win 2");
 if(building_health(YellowCastle) == 0){
   for(scan = 0; scan < ArrayActive[0]; scan++){
     victory(FirstTeam[scan]);
   }
 }
 static Build GreenCastle = find_building(GLOBALS["CastleLeader"], "Castle for win");
 if(building_health(GreenCastle) == 0){
   for(scan = 0; scan < ArrayActive[1]; scan++){
     victory(SecondTeam[scan]);
   }
 }
// =================== Castle max health ===================

  static int CastleHealth = 2000; // Start Health(check \.map)
  int PlusHealth;
  if(timer_expired("Castle max health timer")){
    PlusHealth = object_health(GreenCastle);
    set_object_type_max_health("Castle for win", CastleHealth + 1000);
    set_object_health(GreenCastle, PlusHealth);
    PlusHealth = object_health(YellowCastle);
    set_object_type_max_health("Castle for win 2", CastleHealth + 1000);
    set_object_health(YellowCastle, PlusHealth);
    CastleHealth += 1000;
    set_timer("Castle max health timer", 60);
  }

  if(object_has_buff(YellowCastle, "Build Under Attack Spell"))enable_trigger(YellowPlus);
  trigger YellowPlus(!object_has_buff(YellowCastle, "Build Under Attack Spell") && object_health(YellowCastle) < 100){
    set_timer("YellowCastle Timer", 2);
    give_object_buff(YellowCastle,YellowCastle, "Repair", -1);
  }
  if(timer_expired("YellowCastle Timer") && !object_has_buff(YellowCastle, "Build Under Attack Spell")){
    PlusHealth = object_health(YellowCastle) + 1;
    set_object_health(YellowCastle, PlusHealth);
    enable_trigger(YellowPlus);
  }
  if(object_has_buff(GreenCastle, "Build Under Attack Spell"))enable_trigger(GreenPlus);
  trigger GreenPlus(!object_has_buff(GreenCastle, "Build Under Attack Spell") && object_health(GreenCastle) < 100){
    set_timer("GreenCastle Timer", 2);
    give_object_buff(GreenCastle,GreenCastle, "Repair", -1);
  }
  if(timer_expired("GreenCastle Timer") && !object_has_buff(GreenCastle, "Build Under Attack Spell")){
    PlusHealth = object_health(GreenCastle) + 1;
    set_object_health(GreenCastle, PlusHealth);
    enable_trigger(GreenPlus);
  }
//===================== Units Spawn =========================

if(timer_expired("counter")){
  for(scan = 0; scan < 58; scan++){
    if(sf_ObjNum(1, AllBuilds[scan]) == 0 && counter1[scan] == 0)continue;
    if(counter_num_b1[scan] == 0 && sf_ObjNum(1, AllBuilds[scan]) != 0){
      if(counter1[scan] == 0)sf_Spawn(1, AllBuilds[scan]);
      counter_num_b1[scan] = sf_ObjNum(1, AllBuilds[scan]);
    }
    if(counter_num_b1[scan]!=sf_ObjNum(1, AllBuilds[scan])){
      if(sf_ObjNum(1, AllBuilds[scan]) != 0){
        counter1[scan] = counter1[scan]*90/counter_reset1[scan]/sf_ObjNum(1, AllBuilds[scan]);
        counter_reset1[scan]=90/sf_ObjNum(1, AllBuilds[scan]);
      }
      counter_num_b1[scan]=sf_ObjNum(1, AllBuilds[scan]);
    }
    counter1[scan]++;
    if(counter1[scan] == counter_reset1[scan]){
      counter1[scan] = 0;
      if(sf_ObjNum(1, AllBuilds[scan]) != 0)sf_Spawn(1, AllBuilds[scan]);
    }
  }
  for(scan = 0; scan < 58; scan++){
    if(sf_ObjNum(2, AllBuilds[scan]) == 0 && counter2[scan] == 0)continue;
    if(counter_num_b2[scan] == 0 && sf_ObjNum(2, AllBuilds[scan]) != 0){
      if(counter2[scan] == 0)sf_Spawn(2, AllBuilds[scan]);
      counter_num_b2[scan] = sf_ObjNum(2, AllBuilds[scan]);
    }
    if(counter_num_b2[scan]!=sf_ObjNum(2, AllBuilds[scan])){
      if(sf_ObjNum(2, AllBuilds[scan]) != 0){
        counter2[scan] = counter2[scan]*90/counter_reset2[scan]/sf_ObjNum(2, AllBuilds[scan]);
        counter_reset2[scan]=90/sf_ObjNum(2, AllBuilds[scan]);
      }
      counter_num_b2[scan]=sf_ObjNum(2, AllBuilds[scan]);
    }
    counter2[scan]++;
    if(counter2[scan] == counter_reset2[scan]){
      counter2[scan] = 0;
      if(sf_ObjNum(2, AllBuilds[scan]) != 0)sf_Spawn(2, AllBuilds[scan]);
    }
  }

  set_timer("counter", 1);
}

// ================ Changing time of day ===================

static int ChangeTime = 0;
if(timer_expired("Changing time of day")){
  ChangeTime++;
  switch (ChangeTime){
    case 1:
      set_environment_duration("Desert_Final_night", -1, 300);
      set_timer("Changing time of day", 600);
      break;
    case 2:
      set_environment_duration("Arctic_Final", -1, 300);
      set_timer("Changing time of day", 1200);
      ChangeTime = 0;
      break;
  }
}

// ================= Master Units Buffs =====================

//static int[] Master_units_array1 = [0, 0, 0, 0, 0, 0, 0];
//static BuildType[] Master_units_builds = ["Moon Gorilla 00", "Mega Glass Golem 00", "Land Leviathan 00", "Cuotl Master Unit 00", "Giant Glass Spider 00", "Glass Dragon Start 00", "Thuran, the Sky Inferno 00"];
//trigger Moon_Gorilla_trigger1(Master_units_array1[0] > sf_ObjNum(1, "Moon Gorilla 00"))
//{
	
//}

// ===================== FIGHT AI ==========================
static int current_course;
if(++global_counter >= 15){
  global_counter = 0;
  current_course = sf_give_course(0);
  course = current_course;
  sf_player_num_update();
}
test_size = leader_is_active("1");
if(global_counter < 10){
//BattleRegions = sf_battle_regions(1);
BattleRegions = static_battle_regions;
First_team_combat_units = sf_AllUnits_of_team_that_are_in_combat(1);
Second_team_combat_units = sf_AllUnits_of_team_that_are_in_combat(2);
First_team_location = unit_group_location(First_team_combat_units);
Second_team_location = unit_group_location(Second_team_combat_units);
course_flag = 1;
army_size_test[0] = unit_group_length(First_team_combat_units);
army_size_test[1] = unit_group_length(Second_team_combat_units);
test_locations[0] = location_get_x(First_team_location);
test_locations[1] = location_get_y(First_team_location);
test_locations[2] = location_get_x(Second_team_location);
test_locations[3] = location_get_y(Second_team_location);
//test_units[0] = unit_at_index(First_team_combat_units, 0);
//test_units[1] = unit_at_index(Second_team_combat_units, 0);
//army_size_test = location_get_x(First_team_location);
for(scan = 0; scan < BattleRegions.length; scan++){
  switch(global_counter){
  case 0:
  for(scan2 = 0; scan2 < unit_group_length("AirD"); scan2++){
    the_unit = unit_at_index("AirD", scan2);
    if(unit_can_cast("Barrage", the_unit) && is_unit_in_region(the_unit, BattleRegions[scan])){
    unit_cast_at_unit("Barrage",the_unit, the_unit);
    }
  }
  break;
  case 1:
  for(scan2 = 0; scan2 < unit_group_length("ClockSnipe"); scan2++){
    the_unit = unit_at_index("ClockSnipe", scan2);
    if(unit_can_cast("Clockwork Snipe", the_unit) && is_unit_in_region(the_unit, BattleRegions[scan])){
      the_target = sf_get_target(the_unit, InfantryUnits, NoBuff, 1, 60);     
      if(the_target != "Worker"){
        unit_cast_at_unit("Clockwork Snipe",the_unit, the_target);
      }
    }
  }
  break;
  case 2:
  for(scan2 = 0; scan2 < unit_group_length("GlassSpiders"); scan2++){
    the_unit = unit_at_index("GlassSpiders", scan2);
    if(unit_can_cast("Glass Web 2", the_unit) && is_unit_in_region(the_unit, BattleRegions[scan])){
      the_target = sf_get_target(the_unit, InfantryUnits, SpiderDebuff, 0, 100);
      if(the_target == "Worker")the_target = sf_get_target(the_unit, MediumUnits, SpiderDebuff, 0, 100);
      if(the_target == "Worker")the_target = sf_get_target(the_unit, SmallUnits, SpiderDebuff, 0, 100); 
      if(the_target != "Worker"){
        add(NotHe, the_target);
        add(NotHe_kick, 0);
        GLOBALS["NotHe"] = NotHe;
        unit_cast_at_unit("Glass Web 2",the_unit, the_target);
      }
    }
  }
  break;
  case 3:
  for(scan2 = 0; scan2 < unit_group_length("ClockSpiders"); scan2++){
    the_unit = unit_at_index("ClockSpiders", scan2);
    if(unit_can_cast("Web", the_unit) && is_unit_in_region(the_unit, BattleRegions[scan])){
      the_target = sf_get_target(the_unit, MediumUnits, SpiderDebuff, 0, 100);
      if(the_target == "Worker")the_target = sf_get_target(the_unit, FlyUnits, SpiderDebuff, 0, 100); 
      if(the_target == "Worker")the_target = sf_get_target(the_unit, SmallUnits, SpiderDebuff, 0, 100); 
      if(the_target == "Worker")the_target = sf_get_target(the_unit, InfantryUnits, SpiderDebuff, 0, 100);
      if(the_target != "Worker"){
        add(NotHe, the_target);
        add(NotHe_kick, 0);
        GLOBALS["NotHe"] = NotHe;
        unit_cast_at_unit("Web",the_unit, the_target);
      }
    }
  }
  break;
  case 4:
  for(scan2 = 0; scan2 < unit_group_length("BurrowSpiders"); scan2++){
    the_unit = unit_at_index("BurrowSpiders", scan2);
    if(unit_can_cast("BurrowWeb", the_unit) && is_unit_in_region(the_unit, BattleRegions[scan])){
      the_target = sf_get_target(the_unit, MediumUnits, SpiderDebuff, 0, 100);
      if(the_target == "Worker")the_target = sf_get_target(the_unit, FlyUnits, SpiderDebuff, 0, 100); 
      if(the_target == "Worker")the_target = sf_get_target(the_unit, SmallUnits, SpiderDebuff, 0, 100); 
      if(the_target == "Worker")the_target = sf_get_target(the_unit, InfantryUnits, SpiderDebuff, 0, 100);
      if(the_target != "Worker"){
        add(NotHe, the_target);
        add(NotHe_kick, 0);
        GLOBALS["NotHe"] = NotHe;
        unit_cast_at_unit("BurrowWeb",the_unit, the_target);
      }
    }
  }
  break;
  case 5:
  for(scan2 = 0; scan2 < unit_group_length("Priests"); scan2++){
    the_unit = unit_at_index("Priests", scan2);
    if(unit_can_cast("Personal Shield 1", the_unit) && is_unit_under_attack(the_unit)){
      unit_cast_at_unit("Personal Shield 1",the_unit, the_unit);
    }
    if(unit_can_cast("Planetoid", the_unit) && is_unit_in_region(the_unit, BattleRegions[scan])){
      int k = 1;
      switch(sf_get_unit_team(the_unit)){
        case 1:
          break;
        case 2:
          k = -1;
          break;
      }
      int x = location_get_x(unit_location(the_unit)) + rand_int(10, 24) * k;
      int y = location_get_y(unit_location(the_unit)) + rand_int(-5, 5);
      new_location("Priest_cast", x, y);
      unit_cast_at_location("Planetoid",the_unit, "Priest_cast");
      delete_location("Priest_cast");
    }
  }
  break;
  case 6:
  for(scan2 = 0; scan2 < unit_group_length("GlassGolems"); scan2++){
    the_unit = unit_at_index("GlassGolems", scan2);
    if(unit_can_cast("Rupture", the_unit) && is_unit_in_region(the_unit, BattleRegions[scan])){
      int k = 1;
      switch(sf_get_unit_team(the_unit)){
        case 1:
          break;
        case 2:
          k = -1;
          break;
      }
      int enemy_team;
      if(sf_get_unit_team(the_unit) == 1){enemy_team = 2;
      }else if(sf_get_unit_team(the_unit) == 2)enemy_team = 1;
      int x = location_get_x(unit_group_location(sf_AllUnits_of_team_that_are_in_combat(enemy_team))) + rand_int(12, 16) * k;
      int y;
      int pow = rand_int(0, 2);
      if(x > 290 || x < 110){
        switch (pow){
          case 0:
            y = location_get_y(unit_location(the_unit)) + 15 + rand_int(0, 5);
            break;
          case 1:
            y = location_get_y(unit_location(the_unit)) - 15 + rand_int(0, 5);
            break;
        }
      }else
      { 
        y = location_get_y(unit_group_location(sf_AllUnits_of_team_that_are_in_combat(enemy_team))) + rand_int(-3, 3);
      }
      //int x = location_get_x(unit_location(the_unit)) + rand_int(10, 24) * k;
      //int y = location_get_y(unit_location(the_unit)) + 15*-1^rand_int(0, 2) + rand_int(0, 5);
      new_location("MegaGlassGolem_cast", x, y);
      unit_cast_at_location("Rupture",the_unit, "MegaGlassGolem_cast");
      delete_location("MegaGlassGolem_cast");
    }
  }
  break;
}
}

