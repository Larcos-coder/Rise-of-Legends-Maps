      fill_unit_group(DEATHGOD, sphere_type, "left_top_bridge_group", SpheresToSpawn, "left_top_bridge_loc");
     fill_unit_group(DEATHGOD, fighter_type, "left_top_bridge_group", FightersToSpawn/2*2, "left_top_bridge_loc");

    fill_unit_group(DEATHGOD, grunt_type, "left_bottom_bridge_group", GruntsToSpawn/2*2, "left_bottom_bridge_loc");
     fill_unit_group(DEATHGOD, jaguar_type, "left_bottom_bridge_group", JaguarsToSpawn/2*2, "bottom_bridge_loc");
      fill_unit_group(DEATHGOD, snake_type, "left_bottom_bridge_group", SnakesToSpawn/2*2, "left_bottom_bridge_loc");
      fill_unit_group(DEATHGOD, idol_type, "left_bottom_bridge_group", IdolsToSpawn+2, "left_bottom_bridge_loc");
      fill_unit_group(DEATHGOD, sphere_type, "left_bottom_bridge_group", SpheresToSpawn, "left_bottom_bridge_loc");
     fill_unit_group(DEATHGOD, fighter_type, "left_bottom_bridge_group", FightersToSpawn/2*2, "left_bottom_bridge_loc");

   path_to_choose_left_top_bridge_int = rand_int(0,1);
   path_to_choose_left_bottom_bridge_int = rand_int(0,1);

    switch(path_to_choose_left_top_bridge_int) {

     case 0:
      left_top_bridge_path = "left_top_bridge_path";
      break;

     case 1:
      left_top_bridge_path = "left_top_bridge_path1";
      break;
      }

    switch(path_to_choose_left_bottom_bridge_int) {

     case 0:
      left_bottom_bridge_path = "left_bottom_bridge_path";
      break;

     case 1:
      left_bottom_bridge_path = "left_bottom_bridge_path1";
      break;
      }

       unit_group_attack_to_along_path("left_top_bridge_group", left_top_bridge_path);
       unit_group_attack_to_along_path("left_bottom_bridge_group", left_bottom_bridge_path);

        clear_unit_group("left_top_bridge_group"); 
        clear_unit_group("left_bottom_bridge_group"); 
        }

         enable_trigger("HugeGroupSpawnTrigger");

      set_timer("HugeGroupSpawn", HugeGroupSpawnTime);
  }

  trigger GiantGroupSpawnTrigger(timer_expired("GiantGroupSpawn")) {

  GiantGroupSpawnTime = GiantGroupSpawnTime-20;

   path_to_choose_topbridge_int = rand_int(0,2);

      if(num_units(DEATHGOD) < maxunits) {

    fill_unit_group(DEATHGOD, grunt_type, "top_bridge_group", GruntsToSpawn*3, "top_bridge_loc");
     fill_unit_group(DEATHGOD, jaguar_type, "top_bridge_group", JaguarsToSpawn*2, "top_bridge_loc");
      fill_unit_group(DEATHGOD, snake_type, "top_bridge_group", SnakesToSpawn*2, "top_bridge_loc");
      fill_unit_group(DEATHGOD, idol_type, "top_bridge_group", IdolsToSpawn*2, "top_bridge_loc");
      fill_unit_group(DEATHGOD, sphere_type, "top_bridge_group", SpheresToSpawn+2, "top_bridge_loc");
     fill_unit_group(DEATHGOD, fighter_type, "top_bridge_group", FightersToSpawn*3, "top_bridge_loc");

    switch(path_to_choose_topbridge_int) {

     case 0:
      topbridge_path = "topbridge_path_middle";
      break;

     case 1:
      topbridge_path = "topbridge_path_left";
      break;

     case 2:
      topbridge_path = "topbridge_path_right";
      break;
      }
       unit_group_attack_to_along_path("top_bridge_group", topbridge_path);

        clear_unit_group("top_bridge_group"); 

   path_to_choose_bottombridge_int = rand_int(0,2);
   int city_cointoss = rand_int(0,5);

    fill_unit_group(DEATHGOD, grunt_type, "bottom_bridge_group", GruntsToSpawn*3, "bottom_bridge_loc");
     fill_unit_group(DEATHGOD, jaguar_type, "bottom_bridge_group", JaguarsToSpawn*2, "bottom_bridge_loc");
      fill_unit_group(DEATHGOD, snake_type, "bottom_bridge_group", SnakesToSpawn*2, "bottom_bridge_loc");
      fill_unit_group(DEATHGOD, idol_type, "bottom_bridge_group", IdolsToSpawn*2, "bottom_bridge_loc");
      fill_unit_group(DEATHGOD, sphere_type, "bottom_bridge_group", SpheresToSpawn+2, "bottom_bridge_loc");
     fill_unit_group(DEATHGOD, fighter_type, "bottom_bridge_group", FightersToSpawn*3, "bottom_bridge_loc");

    switch(path_to_choose_bottombridge_int) {

     case 0:
      bottombridge_path = "bottombridge_path_middle";
      break;

     case 1:
      bottombridge_path = "bottombridge_path_left";
      break;

     case 2:
      bottombridge_path = "bottombridge_path_right";
      break;
      }

    switch(city_cointoss) {

     case 0:
      break;

     case 1:
      CitiesToSpawn_1 = 1;
      break;

     case 2:
      break;

     case 3:
      CitiesToSpawn_2 = 1;
      break;

     case 4:
      break;

     case 5:
      CitiesToSpawn_1 = 1;
      CitiesToSpawn_2 = 1;
      break;
      }

      fill_unit_group(DEATHGOD, "Cuotl Master Unit", "bottom_bridge_group", CitiesToSpawn_1, "bottom_bridge_loc");
     fill_unit_group(DEATHGOD, "Cuotl Master Unit", "top_bridge_group", CitiesToSpawn_2, "top_bridge_loc");

       unit_group_attack_to_along_path("bottom_bridge_group", bottombridge_path);
        unit_group_attack_to_along_path("top_bridge_group", topbridge_path);

        clear_unit_group("bottom_bridge_group"); 
        clear_unit_group("top_bridge_group"); 
        }

         enable_trigger("GiantGroupSpawnTrigger");

      set_timer("GiantGroupSpawn", GiantGroupSpawnTime);
  }

  trigger AirGroupSpawnTrigger(timer_expired("AirGroupSpawn")) {

   path_to_choose_topbridge_int = rand_int(0,2);

   int FightersRand = rand_int(1,6);
   int EaglesRand = rand_int(1,5);
   int DisksRand = rand_int(1,4);

   int ShokRand = rand_int(0,3);
   int ShokToSpawn = 0;
   
    switch(ShokRand) {

     case 0:
      ShokToSpawn = 1;
      break;

     case 1:
      ShokToSpawn = 0;
      break;

     case 2:
      ShokToSpawn = 0;
      break;
      
     case 3:
      ShokToSpawn = 0;
      break;
      }   
   
    fill_unit_group(DEATHGOD, "Shok, Goddess of storm", "top_bridge_group", ShokToSpawn, "top_bridge_loc");
      fill_unit_group(DEATHGOD, "Storm Disk", "top_bridge_group", DisksRand, "top_bridge_loc");
      fill_unit_group(DEATHGOD, "Storm Eagle", "top_bridge_group", EaglesRand, "top_bridge_loc");
     fill_unit_group(DEATHGOD, fighter_type, "top_bridge_group", FightersRand, "top_bridge_loc");

    switch(path_to_choose_topbridge_int) {

     case 0:
      topbridge_path = "topbridge_path_middle";
      break;

     case 1:
      topbridge_path = "topbridge_path_left";
      break;

     case 2:
      topbridge_path = "topbridge_path_right";
      break;
      }
      
       unit_group_attack_to_along_path("top_bridge_group", topbridge_path);

        clear_unit_group("top_bridge_group"); 
        
         SupriseAirGroupSpawnTimer = rand_int(60,900);
   
          set_timer("AirGroupSpawn", SupriseAirGroupSpawnTimer);

           enable_trigger("AirGroupSpawnTrigger");
  }

  trigger XilBossSpawn(timer_expired("XilSpawnTimer")) {

   path_to_choose_topbridge_int = rand_int(0,2);
      bubble_text_cent_screen("Xil has appeared!");
      
   int XilSentinels = 12;
   int XilJaguars = 6;
   int XilIdols = 4;
   
      unit_group_jump_move("XilGroup", "bottom_bridge_loc", 180);
      fill_unit_group(DEATHGOD, "Sun Sentinel", "XilDefendersGroup", XilSentinels, "bottom_bridge_loc");
      fill_unit_group(DEATHGOD, "Sun Boss Jaguar", "XilDefendersGroup", XilJaguars, "bottom_bridge_loc");
     fill_unit_group(DEATHGOD, "Sun Boss Idol", "XilDefendersGroup", XilIdols, "bottom_bridge_loc");
  
           if(unit_group_length("red_unit") > 0) {
                         unit_group_attack_to("XilGroup", RedHeroLoc);
                   	  } else if(unit_group_length("blue_unit") > 0) {
                         unit_group_attack_to("XilGroup", BlueHeroLoc);
                   	  } else if(unit_group_length("green_unit") > 0) {
                         unit_group_attack_to("XilGroup", GreenHeroLoc);
                   	  } else if(unit_group_length("yellow_unit") > 0) {
                         unit_group_attack_to("XilGroup", YellowHeroLoc);
                      }
                  

         //SupriseAirGroupSpawnTimer = rand_int(60,900);
         unit_group_guard_unit("XilDefendersGroup", "Xil");
          //set_timer("AirGroupSpawn", SupriseAirGroupSpawnTimer);

           //~ enable_trigger("XilBossSpawn");
           enable_trigger("XilBossStage1");
           enable_trigger("XilBossStage2");
           enable_trigger("XilBossStage3");
           //enable_trigger("XilBossStage4");
  }

  trigger XilBossStage1(unit_health("Xil") < 75) {

    unit_cast_at_unit("Mirror Image", "Xil", "Xil");
  }

  trigger XilBossStage2(unit_health("Xil") < 50) {

    unit_cast_at_unit("Blinding Armor", "Xil", "Xil");
  }

  trigger XilBossStage3(unit_health("Xil") < 30) {

    unit_cast_at_unit("Burning Beams", "Xil", "Xil");
  }

  trigger XilBossStage4(unit_health("Xil") < 15) {

    unit_cast_at_unit("Blinding Armor", "Xil", "Xil");

    set_timer("burn", 11);
    set_timer("clones", 22);

  } 

  trigger (timer_expired("burn")) {
    unit_cast_at_unit("Burning Beams", "Xil", "Xil");
  }

  trigger (timer_expired("clones")) {
    unit_cast_at_unit("Mirror Image", "Xil", "Xil");
  }

///////////////////////////
// DEATHGOD DYNAMIC "AI" //
///////////////////////////

trigger AIMapScan(timer_expired("AIMapScanTimer"))
{

    int TeamHealth = (RedHeroHealth + BlueHeroHealth + GreenHeroHealth + YellowHeroHealth);
    Location TargetLoc[] = [ RedHeroLoc, BlueHeroLoc, GreenHeroLoc, YellowHeroLoc ];

    int id = rand_int(0, 3);

    Location DynamicLoc[] = [ "SpawnerLoc1", "SpawnerLoc2", "SpawnerLoc3", "SpawnerLoc4" ];

    UnitGroup seen_unit = find_unit("5", "");
    UnitGroup unseen_unit;
    /*if(TeamHealth >= TeamHealth/1.5) { // The Heroes Team is doing good

          unit_group_jump_move("DynamicUnitGroup", DynamicLoc[id], 0);
          unit_group_attack_to("DynamicUnitGroup", TargetLoc[id]);*/

    for (int i = 0; i < unit_group_length(unseen_unit); i++)
    {

        Unit curUnit = unit_at_index(unseen_unit, i);

        if ((!is_unit_seen("1", curUnit)) && (!is_unit_seen("2", curUnit)) && (!is_unit_seen("3", curUnit)) && (!is_unit_seen("4", curUnit)))
        {
            add_unit_to_group(unseen_unit, curUnit);
        }
        else
        {
            add_unit_to_group(seen_unit, curUnit);
        }
    }

    //for (int i = 0; i < unit_group_length(unseen_unit); i++)
    //{
    unit_group_jump_move(unseen_unit, DynamicLoc[id], 0);
    unit_group_attack_to(unseen_unit, TargetLoc[id]);

    //int groupSize = unit_group_length(unseen_unit);

    set_timer("AIMapScanTimer", 60);

    enable_trigger("AIMapScan");
    //}
}
}


void function sf_GameSetup() {

 give_good("1", "Timonium", timonium_to_give);
 give_good("2", "Timonium", timonium_to_give);
 give_good("3", "Timonium", timonium_to_give);
 give_good("4", "Timonium", timonium_to_give);

 give_good("1", "Wealth", wealth_to_give);
 give_good("2", "Wealth", wealth_to_give);
 give_good("3", "Wealth", wealth_to_give);
 give_good("4", "Wealth", wealth_to_give);

  create_building("1","Upgrade Shop", "red_shop_loc");
  create_building("2","Upgrade Shop", "blue_shop_loc");
  create_building("3","Upgrade Shop", "green_shop_loc");
  create_building("4","Upgrade Shop", "yellow_shop_loc");

   destroy_building("unfuuni_settings");
   destroy_building("funny_settings");
      
   building_set_int = rand_int(0,4); // Do a coin toss for a set of buildings we want to create

   phrase_to_say = rand_int(0,4); // Say a cool phrase at the beginning of the game ;)

   SupriseAirGroupSpawnTimer = rand_int(60,900);
   
   set_timer("AirGroupSpawn", SupriseAirGroupSpawnTimer);
   
    switch(building_set_int) {

     case 0:
      top_middle_building = "Healing Tower";
      bottom_middle_building = "Healing Tower";
      right_middle_building = "Defense Tower Cuotl";
      left_middle_building = "Defense Tower Cuotl";
      break;

     case 1:
      top_middle_building = "Defense Tower Cuotl";
      bottom_middle_building = "Defense Tower Cuotl";
      right_middle_building = "Healing Tower";
      left_middle_building = "Healing Tower";
      break;

     case 2:
      top_middle_building = "Healing Tower";
      bottom_middle_building = "Defense Tower Cuotl";
      right_middle_building = "Healing Tower";
      left_middle_building = "Defense Tower Cuotl";
      break;

     case 3:
      top_middle_building = "Defense Tower Cuotl";
      bottom_middle_building = "Healing Tower";
      right_middle_building = "Defense Tower Cuotl";
      left_middle_building = "Healing Tower";
      break;

    /* case 4:
      top_middle_building = "";
      bottom_middle_building = "";
      right_middle_building = "";
      left_middle_building = "";
      break;

     case 5:
      top_middle_building = "";
      bottom_middle_building = "";
      right_middle_building = "";
      left_middle_building = "";
      break; */
    }

    switch(phrase_to_say) {

     case 0:
     say_p0 = true;
      break;

     case 1:
     say_p1 = true;
      break;

     case 2:
     say_p2 = true;
      break;

     case 3:
     say_p3 = true;
      break;

     case 4:
     say_p4 = true;
      break;
      }

  create_building("5", top_middle_building, "top_middle_loc");
  create_building("5", bottom_middle_building, "bottom_middle_loc");
  create_building("5", right_middle_building, "right_middle_loc");
  create_building("5", left_middle_building, "left_middle_loc");
  create_building("5", right_middle_building, "right_middle_loc1");
  create_building("5", left_middle_building, "left_middle_loc1");
}

void game_callback on_unit_killed (Unit the_unit) {

  Leader damage_leader = unit_get_damage_leader(the_unit);

    Leader the_leader = get_unit_leader(the_unit); 

  UnitType unit_type = get_unit_type(the_unit);

    Object the_object = get_unit_object(the_unit);

   if (unit_type == "Caliph, the Dune Ruler L1" || unit_type == "Caliph, the Dune Ruler L2" || unit_type == "Caliph, the Dune Ruler L3" || unit_type == "Caliph, the Dune Ruler L4" || unit_type == "Caliph, the Dune Ruler L5" || unit_type == "Geovanni, the Vinci Engineer L1" || unit_type == "Geovanni, the Vinci Engineer L2" ||  unit_type == "Geovanni, the Vinci Engineer L3" ||  unit_type == "Geovanni, the Vinci Engineer L4" ||  unit_type == "Geovanni, the Vinci Engineer L5" || unit_type == "Aizat, the Dark Healer L1" || unit_type == "Aizat, the Dark Healer L2" || unit_type == "Aizat, the Dark Healer L3" || unit_type == "Aizat, the Dark Healer L4" || unit_type == "Aizat, the Dark Healer L5" || unit_type == "Francesco, the Edgy Sniper L1" || unit_type == "Francesco, the Edgy Sniper L2" || unit_type == "Francesco, the Edgy Sniper L3" || unit_type == "Francesco, the Edgy Sniper L4" ||  unit_type == "Francesco, the Edgy Sniper L5") {

    give_good(the_leader, "Prototypes", 1);

     if(the_leader == "1") {

       if(red_num_summons == maxsummons) {

         defeated_red = true;
        }

      } else if(the_leader == "2") {

       if(blue_num_summons == maxsummons) {

         defeated_blue = true;
        }

      } else if(the_leader == "3") {

       if(green_num_summons == maxsummons) {

         defeated_green = true;
    }

      } else if(the_leader == "4") {

       if(yellow_num_summons == maxsummons) {

         defeated_yellow = true;
      }
     }
    }

    if (get_unit_type(the_unit) == "Sentinel" || get_unit_type(the_unit) == "Guardian" || get_unit_type(the_unit) == "Defender") {

        Text bubble_text_msg = Text(5 + "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 5);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if  (get_unit_type(the_unit) == "Sun Jaguar" || get_unit_type(the_unit) == "Veteran Sun Jaguar" || get_unit_type(the_unit) == "Elite Sun Jaguar") {

        Text bubble_text_msg = Text(10 + "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 10);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if  (get_unit_type(the_unit) == "Death Snake" || get_unit_type(the_unit) == "Veteran Death Snake") {

        Text bubble_text_msg = Text(15 + "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 15);  
       give_good(damage_leader, "Research Points", 1);    
    }

    else if  (get_unit_type(the_unit) == "Greater Idol" || get_unit_type(the_unit) == "Elite Greater Idol") {

        Text bubble_text_msg = Text(30 + "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 30);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if  (get_unit_type(the_unit) == "Death Sphere") {

        Text bubble_text_msg = Text(50 + "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 50);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if  (get_unit_type(the_unit) == "Cuotl Master Unit") {

        Text bubble_text_msg = Text(300 + "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 300);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if  (get_unit_type(the_unit) == "Quetzal" || get_unit_type(the_unit) == "Veteran Quetzal" || get_unit_type(the_unit) == "Elite Quetzal") {

        Text bubble_text_msg = Text(10 + "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 10);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if  (get_unit_type(the_unit) == "Storm Disk") {
    
        Text bubble_text_msg = Text(15+ "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 15);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if  (get_unit_type(the_unit) == "Storm Eagle") {
    
        Text bubble_text_msg = Text(20+ "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 20);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if  (get_unit_type(the_unit) == "Shok, Goddess of storm") {
    
        Text bubble_text_msg = Text(45+ "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 45);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if (get_unit_type(the_unit) == "Sun Sentinel") {

        Text bubble_text_msg = Text(15 + "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 15);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if (get_unit_type(the_unit) == "Sun Boss Jaguar") {

        Text bubble_text_msg = Text(25 + "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 25);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if (get_unit_type(the_unit) == "Sun Boss Idol")  {

        Text bubble_text_msg = Text(45 + "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);    
   
       give_good(damage_leader, "Wealth", 45);   
       give_good(damage_leader, "Research Points", 1);   
    }

    else if (get_unit_type(the_unit) == "Xil, the Sun God") {

        Text bubble_text_msg = Text(350 + "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg); 

       give_good(damage_leader, "Wealth", 350);   
       give_good(damage_leader, "Research Points", 1);   
    }
}

void game_callback on_unit_trained(Unit the_unit, Leader the_leader, UnitType the_type, Build the_build) {

 UnitType unit_type = get_unit_type(the_unit);

  if ((the_leader == "1") && (unit_type == "Caliph, the Dune Ruler L1" || unit_type == "Caliph, the Dune Ruler L2" || unit_type == "Caliph, the Dune Ruler L3" || unit_type == "Caliph, the Dune Ruler L4" || unit_type == "Caliph, the Dune Ruler L5" || unit_type == "Geovanni, the Vinci Engineer L1" || unit_type == "Geovanni, the Vinci Engineer L2" ||  unit_type == "Geovanni, the Vinci Engineer L3" ||  unit_type == "Geovanni, the Vinci Engineer L4" ||  unit_type == "Geovanni, the Vinci Engineer L5" || unit_type == "Aizat, the Dark Healer L1" || unit_type == "Aizat, the Dark Healer L2" || unit_type == "Aizat, the Dark Healer L3" || unit_type == "Aizat, the Dark Healer L4" || unit_type == "Aizat, the Dark Healer L5" || unit_type == "Francesco, the Edgy Sniper L1" || unit_type == "Francesco, the Edgy Sniper L2" || unit_type == "Francesco, the Edgy Sniper L3" || unit_type == "Francesco, the Edgy Sniper L4" ||  unit_type == "Francesco, the Edgy Sniper L5" )) {

    add_unit_to_group("red_unit", the_unit);
     
     red_num_summons++;

  } if ((the_leader == "2") && (unit_type == "Caliph, the Dune Ruler L1" || unit_type == "Caliph, the Dune Ruler L2" || unit_type == "Caliph, the Dune Ruler L3" || unit_type == "Caliph, the Dune Ruler L4" || unit_type == "Caliph, the Dune Ruler L5" || unit_type == "Geovanni, the Vinci Engineer L1" || unit_type == "Geovanni, the Vinci Engineer L2" ||  unit_type == "Geovanni, the Vinci Engineer L3" ||  unit_type == "Geovanni, the Vinci Engineer L4" ||  unit_type == "Geovanni, the Vinci Engineer L5" || unit_type == "Aizat, the Dark Healer L1" || unit_type == "Aizat, the Dark Healer L2" || unit_type == "Aizat, the Dark Healer L3" || unit_type == "Aizat, the Dark Healer L4" || unit_type == "Aizat, the Dark Healer L5" || unit_type == "Francesco, the Edgy Sniper L1" || unit_type == "Francesco, the Edgy Sniper L2" || unit_type == "Francesco, the Edgy Sniper L3" || unit_type == "Francesco, the Edgy Sniper L4" ||  unit_type == "Francesco, the Edgy Sniper L5" )) {

    add_unit_to_group("blue_unit", the_unit);

     blue_num_summons++;

  } if ((the_leader == "3") && (unit_type == "Caliph, the Dune Ruler L1" || unit_type == "Caliph, the Dune Ruler L2" || unit_type == "Caliph, the Dune Ruler L3" || unit_type == "Caliph, the Dune Ruler L4" || unit_type == "Caliph, the Dune Ruler L5" || unit_type == "Geovanni, the Vinci Engineer L1" || unit_type == "Geovanni, the Vinci Engineer L2" ||  unit_type == "Geovanni, the Vinci Engineer L3" ||  unit_type == "Geovanni, the Vinci Engineer L4" ||  unit_type == "Geovanni, the Vinci Engineer L5" || unit_type == "Aizat, the Dark Healer L1" || unit_type == "Aizat, the Dark Healer L2" || unit_type == "Aizat, the Dark Healer L3" || unit_type == "Aizat, the Dark Healer L4" || unit_type == "Aizat, the Dark Healer L5" || unit_type == "Francesco, the Edgy Sniper L1" || unit_type == "Francesco, the Edgy Sniper L2" || unit_type == "Francesco, the Edgy Sniper L3" || unit_type == "Francesco, the Edgy Sniper L4" ||  unit_type == "Francesco, the Edgy Sniper L5" )) {

    add_unit_to_group("green_unit", the_unit);

     green_num_summons++;

  } if ((the_leader == "4") && (unit_type == "Caliph, the Dune Ruler L1" || unit_type == "Caliph, the Dune Ruler L2" || unit_type == "Caliph, the Dune Ruler L3" || unit_type == "Caliph, the Dune Ruler L4" || unit_type == "Caliph, the Dune Ruler L5" || unit_type == "Geovanni, the Vinci Engineer L1" || unit_type == "Geovanni, the Vinci Engineer L2" ||  unit_type == "Geovanni, the Vinci Engineer L3" ||  unit_type == "Geovanni, the Vinci Engineer L4" ||  unit_type == "Geovanni, the Vinci Engineer L5" || unit_type == "Aizat, the Dark Healer L1" || unit_type == "Aizat, the Dark Healer L2" || unit_type == "Aizat, the Dark Healer L3" || unit_type == "Aizat, the Dark Healer L4" || unit_type == "Aizat, the Dark Healer L5" || unit_type == "Francesco, the Edgy Sniper L1" || unit_type == "Francesco, the Edgy Sniper L2" || unit_type == "Francesco, the Edgy Sniper L3" || unit_type == "Francesco, the Edgy Sniper L4" ||  unit_type == "Francesco, the Edgy Sniper L5" )) {

    add_unit_to_group("yellow_unit", the_unit);

     yellow_num_summons++;
  }
}

void game_callback on_unit_effected_by_spell (SpellType the_spell, Unit unit_caster, Leader leader_caster, Unit target_unit){

    Object the_object = get_unit_object(unit_caster);
	
    if((target_unit == "Caliph, the Dune Ruler L1") || (target_unit == "Caliph, the Dune Ruler L2") || (target_unit == "Caliph, the Dune Ruler L3") || (target_unit == "Caliph, the Dune Ruler L4") || (target_unit == "Caliph, the Dune Ruler L5") || (target_unit == "Francesco, the Edgy Sniper L1") || (target_unit == "Francesco, the Edgy Sniper L2") || (target_unit == "Francesco, the Edgy Sniper L3") || (target_unit == "Francesco, the Edgy Sniper L4") || (target_unit == "Francesco, the Edgy Sniper L5") || (target_unit == "Geovanni, the Vinci Engineer L1") || (target_unit == "Geovanni, the Vinci Engineer L2") || (target_unit == "Geovanni, the Vinci Engineer L3") || (target_unit == "Geovanni, the Vinci Engineer L4") || (target_unit == "Geovanni, the Vinci Engineer L5") || (target_unit == "Aizat, the Dark Healer L1") || (target_unit == "Aizat, the Dark Healer L2") || (target_unit == "Aizat, the Dark Healer L3") || (target_unit == "Aizat, the Dark Healer L4") || (target_unit == "Aizat, the Dark Healer L5")) { 
    	
      if((the_spell=="Aizat Augmentation 1") || (the_spell=="Aizat Augmentation 2") || (the_spell=="Aizat Augmentation 3") || (the_spell=="Aizat Augmentation 4")) {
       
       give_good(leader_caster, "Wealth", 45);   
       
        Text bubble_text_msg = Text(45+ "#ICON2");

         object_add_bubble_text(the_object, bubble_text_msg);   
 
      } else if ((the_spell=="Healing Beam 1") || (the_spell=="Healing Beam 2") || (the_spell=="Healing Beam 3")  || (the_spell=="Healing Beam 4")){
   
         give_good(leader_caster, "Wealth", 70);   
       
          Text bubble_text_msg = Text(70+ "#ICON2");

           object_add_bubble_text(the_object, bubble_text_msg);   
      }    
   }
}

void ui_callback on_show(string window_id)
{
  if (window_id == "resource_win")
  {
    button_set_title_id("leader", 1, Text(get_leader_name("1")));
    button_set_title_id("leader", 2, Text(get_leader_name("2")));
    button_set_title_id("leader", 3, Text(get_leader_name("3")));
    button_set_title_id("leader", 4, Text(get_leader_name("4")));
    sprite_set_color_to_team("fill_sprite", 1, "1");
    sprite_set_color_to_team("fill_sprite", 2, "2");
    sprite_set_color_to_team("fill_sprite", 3, "3");
    sprite_set_color_to_team("fill_sprite", 4, "4");
  }
}

void ui_callback on_button_clicked(string window, string but_id, int id_num) {
  if (window == "resource_win")
  {

      if (id_num == 1) {

       lock_camera_to_unit(RedHero, 1);
      select_unit_group("red_unit");

    } else if (id_num == 2) {
     
       lock_camera_to_unit(BlueHero, 1);
      select_unit_group("blue_unit");

    } else if (id_num == 3) {

       lock_camera_to_unit(GreenHero, 1);
      select_unit_group("green_unit");

    } else if (id_num == 4) {

       lock_camera_to_unit(YellowHero, 1);
      select_unit_group("yellow_unit");
  }
 }
}
text ui_callback on_label_set_text_id (string window, string label_id, int id_num, text text_msg) {
  
  String lead_str = id_num;
 
   int num = num_type(Leader(lead_str), Type(label_id));
  
  return Text(parse(text_msg, String(num)));
}