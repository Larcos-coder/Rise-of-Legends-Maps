  trigger ExtraUnitSpawnTrigger(timer_expired("ExtraUnitSpawn")) {

   UnitType ExtraOne;
   UnitType ExtraTwo;
   UnitType ExtraThree;
   UnitType ExtraFour;

   int extra_unit_one = rand_int(0,2);
   int extra_unit_two = rand_int(0,2);
   int extra_unit_three = rand_int(0,2);
   int extra_unit_four = rand_int(0,2);

   switch(extra_unit_one) {

     case 0:
      ExtraOne = "Stunner";
      break;

     case 1:
      ExtraOne = "Beamer";
      break;
   }

   switch(extra_unit_two) {

     case 0:
      ExtraTwo = "Stunner";
      break;

     case 1:
      ExtraTwo = "Beamer";
      break;
   }

   switch(extra_unit_three) {

     case 0:
      ExtraThree = "Stunner";
      break;

     case 1:
      ExtraThree = "Beamer";
      break;
   }

   switch(extra_unit_four) {

     case 0:
      ExtraFour = "Stunner";
      break;

     case 1:
      ExtraFour = "Beamer";
      break;
   }
    
    if ((unit_group_length("extraonegroup") < 4)) {
        fill_unit_group(DEATHGOD, ExtraOne, "extraonegroup", 1, "SpawnerLoc1");
    }  if ((unit_group_length("extraonegroup") < 4)) {
    fill_unit_group(DEATHGOD, ExtraTwo, "extraonegroup", 1, "SpawnerLoc2");
    }  if ((unit_group_length("extraonegroup") < 4)) {
    fill_unit_group(DEATHGOD, ExtraThree, "extraonegroup", 1, "SpawnerLoc3");
    }  if ((unit_group_length("extraonegroup") < 4)) {
    fill_unit_group(DEATHGOD, ExtraFour, "extraonegroup", 1, "SpawnerLoc4");
    }

    int AttackGoal = rand_int(1,5);
        switch(extra_unit_one) {
          
     case 1:
      if(unit_group_length("red_unit") > 0){
      unit_group_attack_to("extraonegroup", RedHeroLoc);
      } else if(unit_group_length("blue_unit") > 0){
      unit_group_attack_to("extraonegroup", BlueHeroLoc);
      } else if(unit_group_length("green_unit") > 0){
      unit_group_attack_to("extraonegroup", GreenHeroLoc);
      } else if(unit_group_length("yellow_unit") > 0){
      unit_group_attack_to("extraonegroup", YellowHeroLoc);
      }
      break;
     case 2:
      if(unit_group_length("blue_unit") > 0){
      unit_group_attack_to("extraonegroup", BlueHeroLoc);
      } else if(unit_group_length("red_unit") > 0){
      unit_group_attack_to("extraonegroup", RedHeroLoc);
      } else if(unit_group_length("green_unit") > 0){
      unit_group_attack_to("extraonegroup", GreenHeroLoc);
      } else if(unit_group_length("yellow_unit") > 0){
      unit_group_attack_to("extraonegroup", YellowHeroLoc);
      }
      break;
     case 3:
      if(unit_group_length("green_unit") > 0){
      unit_group_attack_to("extraonegroup", GreenHeroLoc);
      } else if(unit_group_length("red_unit") > 0){
      unit_group_attack_to("extraonegroup", RedHeroLoc);
      } else if(unit_group_length("blue_unit") > 0){
      unit_group_attack_to("extraonegroup", BlueHeroLoc);
      } else if(unit_group_length("yellow_unit") > 0){
      unit_group_attack_to("extraonegroup", YellowHeroLoc);
      }
      break;
     case 4:
      if(unit_group_length("yellow_unit") > 0){
      unit_group_attack_to("extraonegroup", YellowHeroLoc);
      } else if(unit_group_length("red_unit") > 0){
      unit_group_attack_to("extraonegroup", RedHeroLoc);
      } else if(unit_group_length("green_unit") > 0){
      unit_group_attack_to("extraonegroup", GreenHeroLoc);
      } else if(unit_group_length("blue_unit") > 0){
      unit_group_attack_to("extraonegroup", BlueHeroLoc);
      }
      break;
   }

    enable_trigger("ExtraUnitSpawnTrigger");

    set_timer("ExtraUnitSpawn", ExtraUnitSpawnTime);
   }

