  trigger IdleToAttack(timer_expired("idletoattack_timer")) {

        for (int l = 0; l < num_players(); l++)
        {
            UnitGroup allunit = find_unit(get_leader(l), "$ALL$");
            for (int scan = 0; scan < unit_group_length(allunit); scan++)
            {
               Unit the_unit = unit_at_index(allunit, scan);
               Leader the_leader = (get_unit_leader(the_unit));
               if (is_unit_idle(the_unit))
               {
                   if ((the_leader) == "5")
                   {
                   	  if(unit_group_length("red_unit") > 0) {
                         unit_attack_to(the_unit, RedHeroLoc);
                   	  } else if(unit_group_length("blue_unit") > 0) {
                         unit_attack_to(the_unit, BlueHeroLoc);
                   	  } else if(unit_group_length("green_unit") > 0) {
                         unit_attack_to(the_unit, GreenHeroLoc);
                   	  } else if(unit_group_length("yellow_unit") > 0) {
                         unit_attack_to(the_unit, YellowHeroLoc);
                      }
                   }
                }
            }
        }
        set_timer("idletoattack_timer", 15);
    enable_trigger("IdleToAttack");
    }

  trigger(num_type(RED, "TenLives") > 0) {
  
    maxsummons = 11;
    
      destroy_building("funny_settings");
     
       bubble_text_cent_screen("You can resummon your hero 10 times.");  
  }

  trigger(num_type(RED, "IdolHorde") > 0) {
  
    IdolHorde = true; 
     
      destroy_building("unfuuni_settings");
      
       bubble_text_cent_screen("Idols! Incoming!");  
