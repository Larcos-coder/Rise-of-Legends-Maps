  trigger EarlyStart((TimerChosen == true) && (ModeChosen == true)) {
   
   disable_trigger("TimerStart");

    sf_GameSetup();

     set_timer("LightGroupSpawn", LightGroupSpawnTime);
     set_timer("MediumGroupSpawn", MediumGroupSpawnTime);
     set_timer("HugeGroupSpawn", HugeGroupSpawnTime);
     set_timer("GiantGroupSpawn", GiantGroupSpawnTime);
  
     set_timer("GruntUpgrade", GruntUpgradeTime);

     set_timer("AIMapScanTimer", 240);

     add_reveal_point("1", "top_middle_loc", 15);
     add_reveal_point("1", "bottom_middle_loc", 15);
     add_reveal_point("1", "right_middle_loc", 15);
     add_reveal_point("1", "right_middle_loc1", 15);
     add_reveal_point("1", "left_middle_loc", 15);
     add_reveal_point("1", "left_middle_loc1", 15);

      pan_camera("centre_loc", -1, 100);

       create_building(RED, "Border Push", "centre_loc");
      
    BuildGroup BPush = find_building(RED,"Border Push");

   Build BBPush = building_at_index(BPush, 0);
  
    give_object_buff(BBPush, BBPush, "Plot Object", -1);

     set_timer("timerr", 60);

       destroy_building("funny_settings");
       destroy_building("unfuuni_settings");

        set_timer("ExtraUnitSpawn", ExtraUnitSpawnTime);
        set_timer("XilSpawnTimer", GiantGroupSpawnTime+LightGroupSpawnTime);
        set_timer("idletoattack_timer", LightGroupSpawnTime);
  }
    
